</div>

<!-- Unit Tabs -->
<div class="tabs">
  <button class="tab-btn active" data-unit="ALL" onclick="setUnit('ALL')">All Units</button>
  <button class="tab-btn" data-unit="BN ROPALI" onclick="setUnit('BN ROPALI')">BN Ropali</button>
