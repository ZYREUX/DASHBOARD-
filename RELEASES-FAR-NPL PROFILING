    </div>
  </div>

  <!-- Trend Chart -->
  <div class="charts-grid">
    <div class="chart-card">
      <div class="chart-title">📈 FAR1 & NPL Trend (Monthly)</div>
      <div class="chart-wrap"><canvas id="trendChart"></canvas></div>
    </div>
    <div class="chart-card">
      <div class="chart-title">🥧 Risk Category Breakdown</div>
      <div class="chart-wrap"><canvas id="riskChart"></canvas></div>
    </div>
  </div>

  <!-- Bar Charts -->
  <div class="charts-grid2">
    <div class="chart-card">
      <div class="chart-title">📊 Gross FAR1 by Risk Category</div>
