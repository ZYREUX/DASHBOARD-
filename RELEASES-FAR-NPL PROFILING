// Historical PH inflation (%) used to macro-adjust the projection
const INFLATION = {2018:5.2,2019:2.5,2020:2.4,2021:3.9,2022:5.8,2023:6.0,2024:3.2,2025:1.7,2026:4.1};
const AVG_INFLATION = Object.values(INFLATION).reduce((a,b)=>a+b,0)/Object.keys(INFLATION).length;

function linearRegression(points){
  const n = points.length;
  if(n < 2) return {slope:0, intercept: points[0]?points[0].y:0};
  let sumX=0,sumY=0,sumXY=0,sumX2=0;
  points.forEach(p=>{ sumX+=p.x; sumY+=p.y; sumXY+=p.x*p.y; sumX2+=p.x*p.x; });
  const slope = (n*sumXY - sumX*sumY) / (n*sumX2 - sumX*sumX || 1);
  const intercept = (sumY - slope*sumX)/n;
  return {slope, intercept};
}

function pearson(xs, ys){
  const n = xs.length;
  if(n < 2) return 0;
  const mx = xs.reduce((a,b)=>a+b,0)/n, my = ys.reduce((a,b)=>a+b,0)/n;
  let num=0, dx=0, dy=0;
  for(let i=0;i<n;i++){ num += (xs[i]-mx)*(ys[i]-my); dx += (xs[i]-mx)**2; dy += (ys[i]-my)**2; }
  const denom = Math.sqrt(dx*dy);
  return denom ? num/denom : 0;
}

// Projects a monthly rate series 6 months forward using linear regression
// trended with a macro adjustment based on how correlated the metric is
// historically with PH inflation.
function projectSeries(keys, series){
  const points = series.map((y,i)=>({x:i, y}));
  const reg = linearRegression(points);

  const byYear = {};
  keys.forEach((k,i)=>{ const yr = parseInt(k.split('-')[0]); (byYear[yr]=byYear[yr]||[]).push(series[i]); });
  const years = Object.keys(byYear).map(Number).filter(y=>INFLATION[y]!==undefined);
  const avgByYear = years.map(y=>byYear[y].reduce((a,b)=>a+b,0)/byYear[y].length);
  const inflByYear = years.map(y=>INFLATION[y]);
  const correlation = pearson(inflByYear, avgByYear);

  let lastKey = keys[keys.length-1] || '2026-01';
  let lastYear = parseInt(lastKey.split('-')[0]), lastMonth = parseInt(lastKey.split('-')[1]);
  const projKeys = [], projValues = [];
  for(let step=1; step<=6; step++){
    let m = lastMonth+step, y = lastYear;
    while(m>12){ m-=12; y+=1; }
    const x = points.length - 1 + step;
    const trendVal = reg.slope*x + reg.intercept;
    const infl = INFLATION[y] !== undefined ? INFLATION[y] : INFLATION[2026];
    const macroAdj = correlation * (infl - AVG_INFLATION) * 0.5;
    projKeys.push(`${y}-${String(m).padStart(2,'0')}`);
    projValues.push(Math.max(0, trendVal + macroAdj));
  }
  return {projKeys, projValues};
}
const RISK_COLORS = {
  'Green Zone': '#06d6a0',
  'Orange Zone': '#ffd166',
  'Pink Zone': '#f9a8d4',
  'Very High Risk': '#ff6b6b'
};

let allData = [];
let currentUnit = 'ALL';
let currentRisk = 'ALL';
let charts = {};

function parseCSV() {
  return new Promise((resolve, reject) => {
    Papa.parse(EMBEDDED_CSV, { header: true, skipEmptyLines: true, complete: r => resolve(r.data), error: e => reject(e) });
  });
}

async function loadData() {
  document.getElementById('lastUpdate').textContent = 'Loading...';
  try {
    allData = await parseCSV();
    var years = [...new Set(allData.map(r => r['YEAR']).filter(Boolean))].sort();
    var yearSel = document.getElementById('yearFilter');
    yearSel.innerHTML = '<option value="ALL">All Years</option>';
    years.forEach(y => { var o = document.createElement('option'); o.value = y; o.textContent = y; yearSel.appendChild(o); });
    document.getElementById('lastUpdate').textContent = 'Data embedded — Total rows: ' + allData.length + ' (loaded ' + new Date().toLocaleTimeString() + ')';
    applyFilters();
  } catch(e) {
    document.getElementById('lastUpdate').textContent = 'Error loading data.';
    console.error(e);
  }
}

function setUnit(unit) {
  currentUnit = unit;
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.toggle('active', b.dataset.unit === unit));
  applyFilters();
}

function setRisk(risk) {
  currentRisk = risk;
  document.querySelectorAll('.risk-btn').forEach(b => b.classList.toggle('active', b.dataset.risk === risk));
  applyFilters();
}

function getNum(v) { var n = parseFloat(String(v||'0').replace(/,/g,'')); return isNaN(n)?0:n; }

function applyFilters() {
  if (!allData.length) return;
  var year = document.getElementById('yearFilter').value;
  var month = document.getElementById('monthFilter').value;

  var filtered = allData.filter(r => {
    var unitMatch = currentUnit === 'ALL' || r['UNIT'] === currentUnit;
    var riskMatch = currentRisk === 'ALL' || r['RISK CATEGORY'] === currentRisk;
    var yearMatch = year === 'ALL' || String(r['YEAR']) === String(year);
    var monthMatch = month === 'ALL' || String(r['MONTH']) === String(month);
    return unitMatch && riskMatch && yearMatch && monthMatch;
  });

  renderKPIs(filtered);
  renderTrendChart(filtered, year, month);
  renderRiskChart(filtered);
  renderRiskBarCharts(filtered);
  renderSummaryTable(filtered);
  renderMonthlyTable(filtered);
}

function renderKPIs(data) {
  var totalRel = data.reduce((s,r) => s + getNum(r['TOTAL RELEASES']), 0);
  var totalGross = data.reduce((s,r) => s + getNum(r['GROSS FAR 1']), 0);
  var totalNet = data.reduce((s,r) => s + getNum(r['NET FAR 1']), 0);
  var totalNPL = data.reduce((s,r) => s + getNum(r['NPL']), 0);
  var totalLoan = data.reduce((s,r) => s + getNum(r['TOTAL LOAN AMOUNT']), 0);

  var grossPct = totalRel ? (totalGross/totalRel*100) : 0;
  var netPct = totalRel ? (totalNet/totalRel*100) : 0;
  var nplPct = totalRel ? (totalNPL/totalRel*100) : 0;

  var thr = THRESHOLDS[currentUnit] || THRESHOLDS['ALL'];

  document.getElementById('kpi-releases').textContent = totalRel.toLocaleString();
  document.getElementById('kpi-gross').textContent = grossPct.toFixed(1) + '%';
  document.getElementById('kpi-net').textContent = netPct.toFixed(1) + '%';
  document.getElementById('kpi-npl').textContent = nplPct.toFixed(1) + '%';
  document.getElementById('kpi-loan').textContent = '₱' + (totalLoan/1000000).toFixed(1) + 'M';
  document.getElementById('exp-gross').textContent = '≤' + thr.gross + '%';
  document.getElementById('exp-net').textContent = '≤' + thr.net + '%';
  document.getElementById('exp-npl').textContent = '≤' + thr.npl + '%';

  function setThreshold(elId, pct, limit) {
    var el = document.getElementById(elId);
    var diff = pct - limit;
    if (pct <= limit * 0.8) { el.textContent = '✅ Within threshold'; el.className = 'kpi-threshold ok'; }
    else if (pct <= limit) { el.textContent = '⚠️ Approaching limit'; el.className = 'kpi-threshold warn'; }
    else { el.textContent = '🔴 Exceeded by ' + Math.abs(diff).toFixed(1) + '%'; el.className = 'kpi-threshold over'; }
  }
  setThreshold('thr-gross', grossPct, thr.gross);
  setThreshold('thr-net', netPct, thr.net);
  setThreshold('thr-npl', nplPct, thr.npl);
}

function renderTrendChart(data, yearFilter, monthFilter) {
  var ctx = document.getElementById('trendChart').getContext('2d');
  if (charts.trend) charts.trend.destroy();

  var grouped = {};
  data.forEach(r => {
    var key = r['YEAR'] + '-' + String(r['MONTH']).padStart(2,'0');
    if (!grouped[key]) grouped[key] = { rel: 0, gross: 0, net: 0, npl: 0 };
    grouped[key].rel += getNum(r['TOTAL RELEASES']);
    grouped[key].gross += getNum(r['GROSS FAR 1']);
    grouped[key].net += getNum(r['NET FAR 1']);
    grouped[key].npl += getNum(r['NPL']);
  });

  var keys = Object.keys(grouped).sort().slice(-24);
  var labels = keys.map(k => { var p = k.split('-'); return MONTHS[parseInt(p[1])] + ' ' + p[0]; });
  var grossPcts = keys.map(k => grouped[k].rel ? (grouped[k].gross/grouped[k].rel*100) : 0);
  var netPcts = keys.map(k => grouped[k].rel ? (grouped[k].net/grouped[k].rel*100) : 0);
  var nplPcts = keys.map(k => grouped[k].rel ? (grouped[k].npl/grouped[k].rel*100) : 0);

  var thr = THRESHOLDS[currentUnit] || THRESHOLDS['ALL'];

  // --- Projection: next 6 months, using the FULL history (not just the last 24 shown) ---
  var allKeysSorted = Object.keys(grouped).sort();
  var allGrossPcts = allKeysSorted.map(k => grouped[k].rel ? (grouped[k].gross/grouped[k].rel*100) : 0);
  var allNetPcts = allKeysSorted.map(k => grouped[k].rel ? (grouped[k].net/grouped[k].rel*100) : 0);
  var allNplPcts = allKeysSorted.map(k => grouped[k].rel ? (grouped[k].npl/grouped[k].rel*100) : 0);

  var grossProj = projectSeries(allKeysSorted, allGrossPcts);
  var netProj = projectSeries(allKeysSorted, allNetPcts);
  var nplProj = projectSeries(allKeysSorted, allNplPcts);

  var projLabels = grossProj.projKeys.map(k => { var p = k.split('-'); return MONTHS[parseInt(p[1])] + ' ' + p[0]; });
  var fullLabels = labels.concat(projLabels);

  var grossProjLine = new Array(Math.max(grossPcts.length-1,0)).fill(null).concat([grossPcts[grossPcts.length-1]]).concat(grossProj.projValues);
  var netProjLine = new Array(Math.max(netPcts.length-1,0)).fill(null).concat([netPcts[netPcts.length-1]]).concat(netProj.projValues);
  var nplProjLine = new Array(Math.max(nplPcts.length-1,0)).fill(null).concat([nplPcts[nplPcts.length-1]]).concat(nplProj.projValues);

  var grossActualLine = grossPcts.concat(new Array(projLabels.length).fill(null));
  var netActualLine = netPcts.concat(new Array(projLabels.length).fill(null));
  var nplActualLine = nplPcts.concat(new Array(projLabels.length).fill(null));

  charts.trend = new Chart(ctx, {
    type: 'line',
    data: {
      labels: fullLabels,
      datasets: [
        { label: 'Gross FAR1%', data: grossActualLine, borderColor: '#ffd166', backgroundColor: 'rgba(255,209,102,0.1)', borderWidth: 2, tension: 0.4, pointRadius: 3, fill: true, spanGaps:false },
        { label: 'Net FAR1%', data: netActualLine, borderColor: '#a78bfa', backgroundColor: 'rgba(167,139,250,0.1)', borderWidth: 2, tension: 0.4, pointRadius: 3, fill: true, spanGaps:false },
        { label: 'NPL%', data: nplActualLine, borderColor: '#ff6b6b', backgroundColor: 'rgba(255,107,107,0.1)', borderWidth: 2, tension: 0.4, pointRadius: 3, fill: true, spanGaps:false },
        { label: 'Gross Threshold', data: fullLabels.map(() => thr.gross), borderColor: 'rgba(255,209,102,0.4)', borderWidth: 1, borderDash: [5,3], pointRadius: 0 },
        { label: 'NPL Threshold', data: fullLabels.map(() => thr.npl), borderColor: 'rgba(255,107,107,0.4)', borderWidth: 1, borderDash: [5,3], pointRadius: 0 },
        { label: 'Gross Projected', data: grossProjLine, borderColor: '#ffd166', borderWidth: 2, borderDash: [6,4], pointRadius: 0, tension: 0.3, spanGaps:false },
        { label: 'Net Projected', data: netProjLine, borderColor: '#a78bfa', borderWidth: 2, borderDash: [6,4], pointRadius: 0, tension: 0.3, spanGaps:false },
        { label: 'NPL Projected', data: nplProjLine, borderColor: '#ff6b6b', borderWidth: 2, borderDash: [6,4], pointRadius: 0, tension: 0.3, spanGaps:false }
      ]
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      interaction: { mode: 'index', intersect: false },
      plugins: {
        legend: { labels: { color: '#6b7280', font: { size: 10 } } },
        tooltip: { callbacks: { label: c => `${c.dataset.label}: ${c.parsed.y!==null?c.parsed.y.toFixed(2)+'%':'—'}` } }
      },
      scales: {
        x: { ticks: { color: '#6b7280', font: { size: 9 }, maxRotation: 45 }, grid: { color: 'rgba(255,255,255,0.05)' } },
        y: { ticks: { color: '#6b7280', callback: v => v + '%' }, grid: { color: 'rgba(255,255,255,0.05)' } }
      }
    }
  });
}

function renderRiskChart(data) {
  var ctx = document.getElementById('riskChart').getContext('2d');
  if (charts.risk) charts.risk.destroy();
  var risks = ['Green Zone', 'Orange Zone', 'Pink Zone', 'Very High Risk'];
  var counts = risks.map(r => data.filter(d => d['RISK CATEGORY'] === r).reduce((s,d) => s + getNum(d['TOTAL RELEASES']), 0));
  charts.risk = new Chart(ctx, {
    type: 'doughnut',
    data: { labels: risks, datasets: [{ data: counts, backgroundColor: Object.values(RISK_COLORS), borderColor: 'rgba(255,255,255,0.1)', borderWidth: 2 }] },
    options: { responsive: true, maintainAspectRatio: false, cutout: '65%', plugins: { legend: { position: 'bottom', labels: { color: '#6b7280', font: { size: 10 }, boxWidth: 10, padding: 8 } }, tooltip: { callbacks: { label: c => c.label + ': ' + c.raw.toLocaleString() + ' accts' } } } }
  });
}

function renderRiskBarCharts(data) {
  var risks = ['Green Zone', 'Orange Zone', 'Pink Zone', 'Very High Risk'];
  var colors = Object.values(RISK_COLORS);

  function renderBar(id, metricKey, label) {
    var ctx = document.getElementById(id).getContext('2d');
    if (charts[id]) charts[id].destroy();
    var vals = risks.map(r => {
      var rows = data.filter(d => d['RISK CATEGORY'] === r);
      var rel = rows.reduce((s,d) => s + getNum(d['TOTAL RELEASES']), 0);
      var met = rows.reduce((s,d) => s + getNum(d[metricKey]), 0);
      return rel ? (met/rel*100) : 0;
    });
    charts[id] = new Chart(ctx, {
      type: 'bar',
      data: { labels: ['Green', 'Orange', 'Pink', 'Very High'], datasets: [{ label, data: vals, backgroundColor: colors, borderRadius: 6 }] },
      options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { x: { ticks: { color: '#6b7280', font: { size: 10 } }, grid: { display: false } }, y: { ticks: { color: '#6b7280', callback: v => v + '%' }, grid: { color: 'rgba(255,255,255,0.05)' } } } }
    });
  }

  renderBar('grossRiskChart', 'GROSS FAR 1', 'Gross FAR1%');
  renderBar('netRiskChart', 'NET FAR 1', 'Net FAR1%');
  renderBar('nplRiskChart', 'NPL', 'NPL%');
}

function renderSummaryTable(data) {
  var tbody = document.getElementById('summaryTable');
  var grouped = {};
  data.forEach(r => {
    var key = r['YEAR'] + '|' + (currentUnit === 'ALL' ? r['UNIT'] : currentUnit);
    if (!grouped[key]) grouped[key] = { year: r['YEAR'], unit: currentUnit === 'ALL' ? r['UNIT'] : currentUnit, rel: 0, gross: 0, net: 0, npl: 0 };
    grouped[key].rel += getNum(r['TOTAL RELEASES']);
    grouped[key].gross += getNum(r['GROSS FAR 1']);
    grouped[key].net += getNum(r['NET FAR 1']);
    grouped[key].npl += getNum(r['NPL']);
  });

  var rows = Object.values(grouped).sort((a,b) => a.year - b.year || a.unit.localeCompare(b.unit));

  function badge(pct, limit) {
    if (pct <= limit * 0.8) return '<span class="badge ok">✅ OK</span>';
    if (pct <= limit) return '<span class="badge warn">⚠️ Near</span>';
    return '<span class="badge over">🔴 Over</span>';
  }

  tbody.innerHTML = rows.map(r => {
    var thr = THRESHOLDS[r.unit] || THRESHOLDS['ALL'];
    var gp = r.rel ? (r.gross/r.rel*100) : 0;
    var np = r.rel ? (r.net/r.rel*100) : 0;
    var pp = r.rel ? (r.npl/r.rel*100) : 0;
    return `<tr><td>${r.year}</td><td>${r.unit}</td><td>${r.rel.toLocaleString()}</td><td>${r.gross}</td><td>${gp.toFixed(1)}%</td><td>${badge(gp,thr.gross)}</td><td>${r.net}</td><td>${np.toFixed(1)}%</td><td>${badge(np,thr.net)}</td><td>${r.npl}</td><td>${pp.toFixed(1)}%</td><td>${badge(pp,thr.npl)}</td></tr>`;
  }).join('');
}

function renderMonthlyTable(data) {
  var tbody = document.getElementById('monthlyTable');
  var sorted = [...data].sort((a,b) => a['YEAR']-b['YEAR'] || a['MONTH']-b['MONTH']);
  tbody.innerHTML = sorted.slice(0, 100).map(r => {
    var rel = getNum(r['TOTAL RELEASES']);
    var gp = rel ? (getNum(r['GROSS FAR 1'])/rel*100).toFixed(1)+'%' : '0%';
    var np = rel ? (getNum(r['NET FAR 1'])/rel*100).toFixed(1)+'%' : '0%';
    var pp = rel ? (getNum(r['NPL'])/rel*100).toFixed(1)+'%' : '0%';
    return `<tr><td>${r['YEAR']}</td><td>${MONTHS[getNum(r['MONTH'])]}</td><td>${r['UNIT']}</td><td>${r['RISK CATEGORY']}</td><td>${rel.toLocaleString()}</td><td>${getNum(r['GROSS FAR 1'])}</td><td>${gp}</td><td>${getNum(r['NET FAR 1'])}</td><td>${np}</td><td>${getNum(r['NPL'])}</td><td>${pp}</td></tr>`;
  }).join('');
}

loadData();
</script>
</body>
</html>
