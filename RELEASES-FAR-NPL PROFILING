  <button class="risk-btn" data-risk="Orange Zone" onclick="setRisk('Orange Zone')">🟠 Orange Zone</button>
  <button class="risk-btn" data-risk="Pink Zone" onclick="setRisk('Pink Zone')">🩷 Pink Zone</button>
  <button class="risk-btn" data-risk="Very High Risk" onclick="setRisk('Very High Risk')">🔴 Very High Risk</button>
</div>

<!-- Main Tab Content -->
<div id="tab-main" class="tab-content active">

  <!-- KPI Cards -->
  <div class="kpi-grid">
    <div class="kpi-card releases">
      <div class="kpi-label">Total Releases</div>
      <div class="kpi-actual" id="kpi-releases">—</div>
      <div class="kpi-meta">accounts</div>
    </div>
    <div class="kpi-card gross">
      <div class="kpi-label">Gross FAR1</div>
      <div class="kpi-actual" id="kpi-gross">—</div>
      <div class="kpi-meta">Expected: <span id="exp-gross">—</span></div>
